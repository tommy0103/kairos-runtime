{
    "runtime": {
      "runtimeRoot": ".runtime",
      "protoRoot": ".runtime/proto",
      "memoryFilesRoot": ".runtime/memory_files",
      "evolutionsRoot": ".runtime/evolutions"
    },
    "enclaveRuntime": {
      "grpc": {
        "bindAddr": "${ENV:KAIROS_ENCLAVE_SOCKET:-unix:///run/kairos-runtime/sockets/kairos-runtime-enclave.sock}",
        "protoPath": ".runtime/proto/enclave-runtime/enclave.proto"
      },
      "llm": {
        "apiKey": "${ENV:ENCLAVE_API_KEY:-ollama}",
        "baseURL": "${ENV:ENCLAVE_BASE_URL:-http://127.0.0.1:11434/v1}",
        "model": "${ENV:ENCLAVE_MODEL:-qwen3.5:397b-cloud}"
      },
      "tools": {
        "enabled": "all"
      }
    },
    "stateDaemon": {
      "grpc": {
        "enclaveTarget": "${ENV:KAIROS_ENCLAVE_SOCKET:-unix:///run/kairos-runtime/sockets/kairos-runtime-enclave.sock}",
        "vfsTarget": "${ENV:KAIROS_VFS_SOCKET:-unix:///run/kairos-runtime/sockets/kairos-runtime-vfs.sock}"
      },
      "telegram": {
        "botToken": "${ENV:BOT_TOKEN}",
        "ownerUserId": "${ENV:OWNER_USER_ID}"
      },
      "triggers": {
        "editedMessage": "${ENV:TRIGGER_EDITED_MESSAGE:-true}",
        "privateChat": "${ENV:TRIGGER_PRIVATE_CHAT:-true}"
      },
      "model": {
        "llm": {
          "ollama": {
            "baseUrl": "${ENV:OLLAMA_BASE_URL}",
            "model": "qwen3.5:0.8b"
          },
          "cloud": {
            "apiKey": "${ENV:CLOUD_API_KEY:-ollama}",
            "baseURL": "${ENV:CLOUD_BASE_URL:-http://127.0.0.1:11434/v1}",
            "model": "${ENV:CLOUD_MODEL:-qwen3.5:397b-cloud}"
          }
        },
        "embedding": {
          "provider": "ollama",
          "ollamaBaseUrl": "${ENV:OLLAMA_BASE_URL}",
          "ollamaModel": "qwen3-embedding:0.6b"
        }
      }
    }
  }
  
# ============================================
# Telegram 配置
# ============================================

# 运行模式: bot 或 userbot
TELEGRAM_MODE=bot

# --- Bot 模式配置 (TELEGRAM_MODE=bot) ---
# 从 @BotFather 获取的 Bot Token
BOT_TOKEN=your_bot_token_here

# --- UserBot 模式配置 (TELEGRAM_MODE=userbot) ---
# 从 https://my.telegram.org/apps 获取
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# 手机号（带国家码，如 +86138xxxxxxxx）
TELEGRAM_PHONE=+8612345678900

# 两步验证密码（如果有）
TELEGRAM_PASSWORD=

# 管理员用户 ID（用于权限控制）
OWNER_USER_ID=123456789

# ============================================
# 模型配置
# ============================================

# LLM API Key（用于云端模型）
API_KEY=your_api_key_here

# Ollama 服务地址（如果使用本地模型）
OLLAMA_BASE_URL=http://host.docker.internal:11434

# 云端模型配置（可选）
STATE_DAEMON_CLOUD_API_KEY=
STATE_DAEMON_CLOUD_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
STATE_DAEMON_CLOUD_MODEL=

# 嵌入模型配置
EMBED_PROVIDER=ollama
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b

# ============================================
# gRPC 服务配置
# ============================================

# Enclave 服务地址
AGENT_ENCLAVE_TARGET=unix:///tmp/kairos-runtime-enclave.sock
AGENT_ENCLAVE_BIND_ADDR=unix:///tmp/kairos-runtime-enclave.sock

# VFS 服务地址
MEMORY_VFS_TARGET=/tmp/kairos-runtime-vfs.sock

# ============================================
# 运行时配置
# ============================================

# 配置文件根目录
APPCONFIG_ROOT=.runtime/appconfig

# 配置文件环境（local, production, sandbox）
APPCONFIG_PROFILE=local

# 内存文件根目录
MEMORY_FILES_ROOT=.runtime/memory_files

# 工具进化目录
EVOLUTIONS_ROOT=.runtime/evolutions

# ============================================
# 沙箱配置（可选）
# ============================================

# 沙箱镜像
SANDBOX_IMAGE=debian:slim

# 干运行模式（调试）
SANDBOX_DRY_RUN=0

# ============================================
# 其他配置
# ============================================

# 日志级别
LOG_LEVEL=info

# 开发模式
NODE_ENV=development

{
  "name": "kairos-runtime",
  "version": "1.0.50",
  "private": true,
  "workspaces": [
    "src/state-daemon",
    "src/enclave-runtime"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:embed": "bun run src/test-embed.ts",
    "dev": "concurrently \"bun run --cwd src/state-daemon dev\" \"bun run --cwd src/enclave-runtime dev\"",
    "dev:state": "bun run --cwd src/state-daemon dev",
    "dev:enclave": "bun run --cwd src/enclave-runtime dev",
    "proto:gen:vfs": "grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/storage/vfs/generated --ts_proto_opt=esModuleInterop=true,env=node,forceLong=number,useExactTypes=false,outputServices=nice-grpc,outputServices=generic-definitions -I src/vfs/proto src/vfs/proto/vfs.proto",
    "proto:gen": "bun run proto:gen:vfs"
  },
  "devDependencies": {
    "bun-types": "latest",
    "concurrently": "^9.2.1",
    "grpc-tools": "^1.13.1",
    "ts-proto": "^2.11.4"
  },
  "module": "src/index.js"
}

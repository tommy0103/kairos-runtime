# ============================================
# Telegram 配置
# ============================================

# 运行模式: bot 或 userbot
TELEGRAM_MODE=bot

# --- Bot 模式配置 (TELEGRAM_MODE=bot) ---
BOT_TOKEN=your_bot_token_here

# --- UserBot 模式配置 (TELEGRAM_MODE=userbot) ---
# 从 https://my.telegram.org/apps 获取
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+8612345678900
TELEGRAM_PASSWORD=
TELEGRAM_SESSION_STRING=
TELEGRAM_SILENT_STREAM=true

# 管理员用户 ID
OWNER_USER_ID=123456789

# ============================================
# 模型配置 (核心对话)
# ============================================

# 主对话 API Key
API_KEY=your_api_key_here
BASE_URL=https://api.deepseek.com/v1
MODEL=deepseek-chat

# ============================================
# 模型配置 (辅助功能)
# ============================================

# 总结归档用 (State Daemon)
STATE_DAEMON_CLOUD_API_KEY=
STATE_DAEMON_CLOUD_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
STATE_DAEMON_CLOUD_MODEL=

# Ollama 服务 (Embedding & 本地模型)
OLLAMA_BASE_URL=http://127.0.0.1:11434
EMBED_PROVIDER=ollama
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b

# ============================================
# gRPC & 路径配置 (通常保持默认)
# ============================================

KAIROS_ENCLAVE_SOCKET=unix:///run/kairos-runtime/sockets/kairos-runtime-enclave.sock
KAIROS_VFS_SOCKET=unix:///run/kairos-runtime/sockets/kairos-runtime-vfs.sock

MEMORY_FILES_ROOT=.runtime/memory_files
EVOLUTIONS_ROOT=.runtime/evolutions
APPCONFIG_ROOT=.runtime/appconfig
APPCONFIG_PROFILE=local

# ============================================
# 其他配置
# ============================================

LOG_LEVEL=info
NODE_ENV=development
SANDBOX_IMAGE=debian:slim
SANDBOX_DRY_RUN=0

# ============================================================
# memoh-lite 环境变量配置
# 复制本文件为 .env 并填入你的值
# ============================================================

# ── Telegram 机器人 ──────────────────────────────────────────
# (必填) 从 @BotFather 获取的 Bot Token
BOT_TOKEN=

# (可选) 机器人主人的 Telegram 用户 ID，设置后自动授予 owner 角色
OWNER_USER_ID=

# ── 主 Agent 大模型 ─────────────────────────────────────────
# (必填) 主 Agent 的 API Key，未设置时回退到 QWEN_API_KEY
API_KEY=
# QWEN_API_KEY=

# 主 Agent 模型的 Base URL
# 默认: https://coding.dashscope.aliyuncs.com/v1
# 其他可选:
#   https://ark.cn-beijing.volces.com/api/v3   (火山引擎 / 豆包)
#   https://api.kimi.com/coding/v1             (Kimi)
#   https://api.openai.com/v1                  (OpenAI)
#   https://api.deepseek.com/v1                (DeepSeek)
BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# 主 Agent 使用的模型名称
# 默认: qwen3-coder-next
# 其他可选: doubao-seed-2-0-pro-260215, kimi-k2.5, gpt-5-mini-2025-08-07
MODEL=qwen3-coder-next

# ── 会话分类 / 总结模型 (Summarizer) ────────────────────────
# 用于会话分类和话题摘要的轻量云端模型的 API Key
SUMMARIZER_API_KEY=

# 总结模型的 Base URL
# 默认: https://ark.cn-beijing.volces.com/api/v3
# SUMMARIZER_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 总结模型名称
# 默认: doubao-seed-2-0-lite-260215
# SUMMARIZER_MODEL=doubao-seed-2-0-lite-260215

# ── 备用 API Key (按需取消注释) ─────────────────────────────
# KIMI_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# ── Agent Enclave (gRPC 分进程模式) ─────────────────────────
# 设置后，主进程通过 gRPC 连接远程 Enclave 服务器，
# 而不是在进程内运行 Agent
# AGENT_ENCLAVE_TARGET=127.0.0.1:50051

# Enclave gRPC 服务器监听地址
# 默认: 0.0.0.0:50051
# AGENT_ENCLAVE_BIND_ADDR=0.0.0.0:50051

# ── 工具配置 ─────────────────────────────────────────────────
# 启用的工具名称，逗号分隔，或填 "all" 启用全部
# 可选: fetch_webpage, update_user_memory
# 默认: all
# ENABLED_TOOLS=all

# 是否保留 evolute 动态生成的工具模块文件 (设为 "1" 启用)
# EVOLUTE_KEEP_MODULES=0

# ── Embedding 向量化 (Ollama) ───────────────────────────────
# 向量化提供者: "ollama" | "native"
# 默认: ollama
# EMBED_PROVIDER=ollama

# Ollama 服务器地址
# 默认: http://127.0.0.1:11434
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Ollama Embedding 模型 (未设置时根据内存自动选择)
# 默认: bge-m3 (≥8GB) / qllama/bge-m3:q8_0 (≥4GB) / qllama/bge-m3:q4_k_m
# OLLAMA_EMBED_MODEL=bge-m3

# ── Ollama 本地对话模型 (会话分类回退) ──────────────────────
# 本地 Ollama 对话模型名称
# 默认: qwen3:4b
# OLLAMA_SESSION_MODEL=qwen3:4b

# ── Reranker 重排序服务 ─────────────────────────────────────
# Reranker API 地址 (对应 reranker_server.py)
# 默认: http://127.0.0.1:8008/rerank
# RERANKER_API_URL=http://127.0.0.1:8008/rerank

# Reranker 请求超时时间 (毫秒)
# 默认: 2500
# RERANKER_TIMEOUT_MS=2500

# 将消息归入已有会话的最低分数阈值
# 默认: 0.32
# RERANKER_ASSIGN_THRESHOLD=0.32

# ── Reranker Python 服务端 (reranker_server.py) ─────────────
# CrossEncoder 重排序模型名称
# 默认: BAAI/bge-reranker-v2-m3
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 重排序模型最大输入 token 长度
# 默认: 512
# RERANKER_MAX_LENGTH=512

# Reranker 服务监听地址和端口
# 默认: 0.0.0.0:8008
# RERANKER_HOST=0.0.0.0
# RERANKER_PORT=8008

# ── 杂项 ─────────────────────────────────────────────────────
# 覆盖发送给 LLM API 的 User-Agent 请求头
# OPENAI_FORCE_USER_AGENT=

# ── Benchmark 基准测试 (仅开发用) ───────────────────────────
# BENCH_PARQUET=./irc_disentangle/ubuntu/train-00000-of-00001.parquet
# BENCH_DRAMATIC_PATH=./dramatic-conversation-disentanglement/data/train.tsv
